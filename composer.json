{
    "name": "a2zwebltd/auditable-relations",
    "description": "Automatic auditing for Eloquent relationship changes (attach, detach, sync) using Laravel Auditing",
    "keywords": [
        "laravel",
        "eloquent",
        "auditing",
        "pivot",
        "relationships",
        "many-to-many"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "A2Z Web Ltd",
            "email": "nick@a2zweb.co"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "owen-it/laravel-auditing": "^13.0|^14.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "A2ZWeb\\AuditableRelations\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "A2ZWeb\\AuditableRelations\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "A2ZWeb\\AuditableRelations\\AuditableRelationsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    }
}
